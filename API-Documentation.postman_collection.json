                        "url": { "raw": "{{baseUrl}}/admin/orders/1/status", "host": ["{{baseUrl}}"], "path": ["admin", "orders", "1", "status"] },
                        "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\"\n}" }
