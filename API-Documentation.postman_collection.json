                        "url": { "raw": "{{baseUrl}}/admin/1/update", "host": ["{{baseUrl}}"], "path": ["admin", "1", "update"] },
                        "body": { "mode": "raw", "raw": "{\n  \"role\": \"superadmin\"\n}" }
                    }
                },
                {
                    "name": "Delete Admin",
                    "request": {
                        "method": "DELETE",
                        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
                        "url": { "raw": "{{baseUrl}}/admin/1", "host": ["{{baseUrl}}"], "path": ["admin", "1"] }
                    }
                },
                {
                    "name": "Dashboard",
                    "request": {
                        "method": "GET",
                        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
                        "url": { "raw": "{{baseUrl}}/admin/dashboard", "host": ["{{baseUrl}}"], "path": ["admin", "dashboard"] }
                    }
                },
