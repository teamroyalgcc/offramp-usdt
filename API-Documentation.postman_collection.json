                        "url": { "raw": "{{baseUrl}}/admin/manual-credit", "host": ["{{baseUrl}}"], "path": ["admin", "manual-credit"] },
                        "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"USER_UUID_HERE\",\n  \"amount\": 100,\n  \"currency\": \"USDT\"\n}" }
                    }
                },
