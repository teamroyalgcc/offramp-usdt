                    "name": "KYC List",
                    "request": {
                        "method": "GET",
                        "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
                        "url": { "raw": "{{baseUrl}}/admin/kyc", "host": ["{{baseUrl}}"], "path": ["admin", "kyc"] }
                    }
                },
