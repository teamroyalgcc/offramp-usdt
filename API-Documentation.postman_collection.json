                        "url": { "raw": "{{baseUrl}}/admin/kyc/1/reject", "host": ["{{baseUrl}}"], "path": ["admin", "kyc", "1", "reject"] },
                        "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Document unclear\"\n}" }
                    }
